{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for SocaDB",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:menu:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-ask",
    "dialog:allow-message",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/.claude.json" },
        { "path": "$HOME/Library/Application Support/Claude/**" },
        { "path": "$HOME/.codex/**" },
        { "path": "$HOME/.socadb/**" }
      ]
    }
  ]
}
