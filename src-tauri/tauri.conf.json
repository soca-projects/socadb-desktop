{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "SocaDB",
  "version": "0.1.1",
  "identifier": "com.socadb.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build:all",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SocaDB",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "deb", "appimage", "nsis"],
    "resources": {
      "../mcp-server/dist/socadb-mcp-*": "",
      "../mcp-server/dist/runtime/": "runtime/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUzMjJBRkY3RjkyREFEQTAKUldTZ3JTMzU5NjhpNDlMYzloeFcvbWxCajl5cVdsMjFURGF3dm1vNEVyK2RWUXNKb3Z1YllnSlMK",
      "endpoints": [
        "https://github.com/soca-projects/socadb-desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
