{
  "default": {
    "identifier": "default",
    "description": "Default permissions for SocaDB",
    "local": true,
    "windows": ["main"],
    "permissions": [
      "core:default",
      "dialog:default",
      "dialog:allow-open",
      "dialog:allow-save",
      "dialog:allow-ask",
      "dialog:allow-message",
      "fs:default",
      "fs:allow-read-text-file",
      "fs:allow-write-text-file",
      "fs:allow-exists"
    ]
  }
}
